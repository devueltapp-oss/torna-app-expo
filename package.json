{
  "name": "torna-refactor",
  "version": "1.0.0",
  "main": "index.ts",
  "scripts": {
    "test": "jest",
    "test:watch": "jest --watch",
    "start": "expo start --port 8081",
    "kill-metro": "npx kill-port 8081 8081",
    "android": "npx kill-port 8081 8081 && expo run:android --port 8081",
    "ios": "expo run:ios",
    "web": "expo start --web --port 8081",
    "android:local": "expo run:android --port 8081",
    "android:device": "expo run:android --device --port 8081",
    "ios:local": "expo run:ios",
    "ios:device": "expo run:ios --device",
    "build:android": "eas build --platform android --profile preview",
    "build:ios": "eas build --platform ios --profile preview",
    "build:all": "eas build --platform all --profile preview",
    "preview:android": "eas build --platform android --profile preview",
    "update:android": "eas update --branch preview --platform android --message \"OTA update\"",
    "deploy:android": "eas build --platform android --profile production",
    "deploy:ios": "eas build --platform ios --profile production",
    "submit:android": "eas submit --platform android --profile production",
    "submit:ios": "eas submit --platform ios --profile production",
    "release:android": "eas build --platform android --profile production && eas submit --platform android --profile production",
    "release:ios": "eas build --platform ios --profile production && eas submit --platform ios --profile production"
  },
  "dependencies": {
    "@react-native-async-storage/async-storage": "1.23.1",
    "@react-native-firebase/app": "^20.5.0",
    "@react-native-firebase/auth": "^20.5.0",
    "@react-native-google-signin/google-signin": "^13.2.0",
    "@react-navigation/native": "^6.1.17",
    "@react-navigation/native-stack": "^6.10.0",
    "expo": "~51.0.0",
    "expo-apple-authentication": "~6.4.2",
    "expo-av": "~14.0.7",
    "expo-build-properties": "~0.12.5",
    "expo-dev-client": "~4.0.29",
    "expo-file-system": "~17.0.1",
    "expo-font": "~12.0.0",
    "expo-image-picker": "~15.0.7",
    "expo-secure-store": "~13.0.2",
    "expo-status-bar": "~1.12.0",
    "expo-system-ui": "~3.0.7",
    "lucide-react-native": "^0.395.0",
    "onesignal-expo-plugin": "^2.5.0",
    "react": "18.2.0",
    "react-native": "0.74.5",
    "react-native-create-thumbnail": "^2.2.0",
    "react-native-gesture-handler": "~2.16.1",
    "react-native-onesignal": "~5.2.10",
    "react-native-safe-area-context": "4.10.5",
    "react-native-screens": "3.31.1",
    "react-native-svg": "15.2.0"
  },
  "devDependencies": {
    "@babel/core": "^7.20.0",
    "@testing-library/react-native": "^12.5.2",
    "@types/jest": "^29.5.12",
    "@types/node": "^25.9.2",
    "@types/react": "~18.2.79",
    "jest": "^29.7.0",
    "jest-expo": "~51.0.0",
    "react-test-renderer": "18.2.0",
    "typescript": "~5.3.3"
  },
  "private": true,
  "_authInstall": [
    "npx expo install @react-native-firebase/app @react-native-firebase/auth",
    "npx expo install expo-secure-store",
    "npx expo install expo-apple-authentication",
    "npx expo install @react-native-google-signin/google-signin",
    "npx expo install react-native-fbsdk-next",
    "After installing: remove the stub SecureStore shim in contexts/AuthContext.tsx and uncomment the real SDK imports (search for TODO: replace)"
  ]
}
